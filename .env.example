# ─── CoMUN 2026 — Environment Variables ──────────────────────────────────
# Copy to `.env` and fill in. NEVER commit the real `.env`.
#
# DEPLOYMENT SPLIT:
#   • Frontend  → Vercel  (only needs VITE_* vars below)
#   • Backend   → Netlify Functions (needs DATABASE_URL, JWT, R2, Brevo, etc.)
# Set each group of vars in the matching host's dashboard.

# ── Frontend (Vercel) ──
# Absolute URL of the deployed Netlify Functions API, e.g.
#   https://comun-api.netlify.app/api
# Leave blank locally to use the relative '/api' (netlify dev).
VITE_API_BASE_URL=""

# ── Database (Neon PostgreSQL) ──
# Pooled connection string for serverless (Netlify Functions).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require"

# ── Auth ──
JWT_SECRET="replace-with-a-long-random-secret"
# Admin session length (hours). Spec: 5h for Admin; Super Admin never expires.
ADMIN_SESSION_HOURS="5"

# ── Bootstrap Super Admin (used once by the seed script) ──
SUPERADMIN_NAME="CoMUN Secretariat"
SUPERADMIN_EMAIL="superadmin@cottons.edu"
SUPERADMIN_PHONE="+910000000000"
SUPERADMIN_USERNAME="superadmin"
SUPERADMIN_PASSWORD="change-me-on-first-login"

# ── Cloudflare R2 (S3-compatible) ──
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="comun-uploads"
# e.g. https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT=""
# Optional public base URL for served resources (custom domain / r2.dev)
R2_PUBLIC_BASE_URL=""

# ── Email (Brevo SMTP) ──
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT="587"
BREVO_SMTP_USER=""
BREVO_SMTP_PASS=""
EMAIL_FROM="CoMUN 2026 <noreply@cottons.edu>"

# ── App ──
# Public site origin (used in emails / links).
PUBLIC_SITE_URL="http://localhost:5173"
